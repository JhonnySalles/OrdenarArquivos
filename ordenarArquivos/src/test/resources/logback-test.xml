<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silenciando bibliotecas barulhentas -->
    <logger name="com.sun.javafx" level="ERROR"/>
    <logger name="javafx" level="ERROR"/>
    <logger name="com.jfoenix" level="ERROR"/>
    <logger name="org.testfx" level="ERROR"/>
    <logger name="org.hibernate" level="ERROR"/>
    <logger name="org.flywaydb" level="ERROR"/>
    <logger name="org.xerial.sqlite" level="ERROR"/>

    <!-- Mantendo logs do projeto em INFO por padrão -->
    <logger name="com.fenix.ordenararquivos" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
