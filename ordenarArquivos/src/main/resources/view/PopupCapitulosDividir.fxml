<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="300.0" styleClass="background-Black2" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fenix.ordenararquivos.controller.PopupCapitulosDividirController">
   <children>
      <VBox spacing="30.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>
            <JFXTextField fx:id="txtInicio" focusColor="#71afe5" labelFloat="true" promptText="Capítulo Inicial" styleClass="texto-stilo-1" unFocusColor="#106ebe" />
            <JFXTextField fx:id="txtFim" focusColor="#71afe5" labelFloat="true" promptText="Capítulo Final" styleClass="texto-stilo-1" unFocusColor="#106ebe" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="25.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
