<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import com.jfoenix.controls.JFXSlider?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane minHeight="450.0" minWidth="600.0" prefHeight="700.0" prefWidth="900.0" styleClass="background-Black3" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fenix.ordenararquivos.controller.PopupVisualizarSumarioController">
   <stylesheets>
      <URL value="@../css/Dark_TelaInicial.css" />
      <URL value="@../css/Paleta_Cores.css" />
   </stylesheets>
   <children>
      <VBox prefHeight="200.0" prefWidth="100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <AnchorPane fx:id="apImage" style="-fx-background-color: black;" VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER" prefHeight="60.0" prefWidth="200.0" spacing="20.0" styleClass="background-Black2">
               <children>
                  <Label text="Zoom:" textFill="WHITE" />
                  <JFXSlider fx:id="sliderZoom" max="10.0" min="0.1" value="1.0" />
                  <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
                     <children>
                        <JFXButton fx:id="btnCancelar" onAction="#onBtnCancelar" prefHeight="35.0" prefWidth="120.0" styleClass="background-Red2" text="Cancelar" textFill="WHITE" />
                        <JFXButton fx:id="btnOcr" onAction="#onBtnOcr" prefHeight="35.0" prefWidth="150.0" styleClass="background-Blue3" text="Processar OCR" textFill="WHITE" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets left="20.0" right="20.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
