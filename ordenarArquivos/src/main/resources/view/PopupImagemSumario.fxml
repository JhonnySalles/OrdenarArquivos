<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXSlider?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane minHeight="450.0" minWidth="600.0" prefHeight="700.0" prefWidth="900.0" styleClass="background-Black2" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fenix.ordenararquivos.controller.PopupImagemSumarioController">
   <stylesheets>
      <URL value="@../css/Dark_TelaInicial.css" />
      <URL value="@../css/Paleta_Cores.css" />
   </stylesheets>
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <AnchorPane fx:id="apImage" style="-fx-background-color: black;" VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" minHeight="40.0" prefHeight="40.0" spacing="10.0">
               <children>
                  <Label text="Zoom:" textFill="WHITE" />
                  <JFXSlider fx:id="sliderZoom" max="10.0" min="0.1" prefWidth="200.0" value="1.0" />
               </children>
               <padding>
                  <Insets left="15.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
