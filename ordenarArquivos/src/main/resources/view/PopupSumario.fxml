<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import com.jfoenix.controls.JFXTextField?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="apRoot" minHeight="500.0" minWidth="800.0" prefHeight="700.0" prefWidth="1000.0" styleClass="background-Black2" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fenix.ordenararquivos.controller.PopupSumarioController">
    <stylesheets>
        <URL value="@../css/Dark_TelaInicial.css" />
        <URL value="@../css/Paleta_Cores.css" />
    </stylesheets>
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <JFXTextField fx:id="txtEndereco" focusColor="#71afe5" promptText="Endereço" styleClass="texto-stilo-1" unFocusColor="#106ebe80" HBox.hgrow="ALWAYS" />
                  <JFXButton fx:id="btnArquivo" contentDisplay="GRAPHIC_ONLY" onAction="#onBtnArquivo" styleClass="background-Black3">
                     <graphic>
                        <ImageView fitHeight="17.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/icoAbrir_48.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </JFXButton>
                  <JFXButton fx:id="btnExecutar" onAction="#onBtnExecutar" prefHeight="30.0" prefWidth="110.0" styleClass="background-Green2" text="Executar" textFill="WHITE" />
                    </children>
                </HBox>
                <SplitPane dividerPositions="0.5" styleClass="background-Black2" VBox.vgrow="ALWAYS">
                    <items>
                          <TableView fx:id="tbViewProcessar" styleClass="table-view-dark">
                              <columns>
                                  <TableColumn fx:id="clArquivoEsquerda" minWidth="100.0" prefWidth="200.0" text="Arquivo" />
                                  <TableColumn fx:id="clSerieEsquerda" minWidth="100.0" prefWidth="150.0" text="Série" />
                                  <TableColumn fx:id="clVolumeEsquerda" minWidth="50.0" prefWidth="70.0" text="Volume" />
                                  <TableColumn fx:id="clProcessar" minWidth="200.0" prefWidth="250.0" text="Resumo Atual" />
                              </columns>
                              <columnResizePolicy>
                                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                              </columnResizePolicy>
                          </TableView>
                          <TableView fx:id="tbViewSumario" editable="true" styleClass="table-view-dark">
                              <columns>
                                  <TableColumn fx:id="clVolumeExtraido" minWidth="50.0" prefWidth="60.0" text="Extraído" />
                                  <TableColumn fx:id="clVolumeVinculado" minWidth="50.0" prefWidth="70.0" text="Vinculado" />
                                  <TableColumn fx:id="clSumario" minWidth="100.0" prefWidth="400.0" text="Resumo Extraído" />
                              </columns>
                              <columnResizePolicy>
                                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                              </columnResizePolicy>
                          </TableView>
                    </items>
                </SplitPane>
            </children>
        </VBox>
        <AnchorPane fx:id="apDragOverlay" visible="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <StackPane fx:id="spDragDropZone" style="-fx-background-color: rgba(0,0,0,0.5);" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
                    <children>
                        <Label fx:id="lblDragDrop" text="Arraste o arquivo ou cole o texto aqui" textFill="WHITE">
                            <style>
                                -fx-font-size: 24px;
                                -fx-font-weight: bold;
                            </style>
                        </Label>
                    </children>
                </StackPane>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
