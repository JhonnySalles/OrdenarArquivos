<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXCheckBox?>
<?import com.jfoenix.controls.JFXTextField?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="480.0" styleClass="background-Black2" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fenix.ordenararquivos.controller.PopupSubstituirController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>
            <JFXTextField fx:id="txtLocalizar" focusColor="#71afe5" labelFloat="true" promptText="Localizar (Regex)" styleClass="texto-stilo-1" unFocusColor="#106ebe" />
            <JFXTextField fx:id="txtSubstituir" focusColor="#71afe5" labelFloat="true" promptText="Substituir por" styleClass="texto-stilo-1" unFocusColor="#106ebe" />
            <JFXCheckBox fx:id="ckbRegex" checkedColor="#0cff00" selected="true" text="Regex" textFill="WHITE" unCheckedColor="WHITE" />
            <VBox spacing="8.0">
               <children>
                  <Label style="-fx-font-size: 11px; -fx-font-weight: bold;" text="Sugestões rápidas:" textFill="#71afe5" />
                  <HBox fx:id="hbSugestoes" alignment="CENTER_LEFT" spacing="8.0" />
               </children>
            </VBox>
            <VBox fx:id="vbPreview" spacing="8.0" visible="false">
               <children>
                  <Label style="-fx-font-size: 11px; -fx-font-weight: bold;" text="Exemplos de substituição:" textFill="#71afe5" />
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <VBox fx:id="vbOriginal" spacing="6.0" />
                        <VBox fx:id="vbSubstituido" spacing="6.0" />
                      </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="20.0" />
         </padding>
      </VBox>
   </children>
   <stylesheets>
      <URL value="@../css/Dark_TelaInicial.css" />
      <URL value="@../css/Paleta_Cores.css" />
   </stylesheets>
</AnchorPane>
