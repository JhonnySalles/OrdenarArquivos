<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import com.jfoenix.controls.JFXTabPane?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="apGlobal" minHeight="700.0" minWidth="700.0" prefHeight="700.0" prefWidth="800.0" styleClass="background-Black1" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fenix.ordenararquivos.controller.TelaInicialController">
   <children>
      <StackPane fx:id="spGlobal" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <AnchorPane>
               <children>
                  <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <children>
                        <JFXTabPane fx:id="tpGlobal" VBox.vgrow="ALWAYS">
                           <tabs>
                              <Tab fx:id="tbTabArquivo" onSelectionChanged="#onSelectChanged" text="Arquivo">
                                 <content>
                                    <AnchorPane fx:id="arquivo" prefHeight="200.0" prefWidth="200.0">
                                       <children>
                                          <fx:include fx:id="arquivo" source="AbaArquivo.fxml" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                       </children>
                                    </AnchorPane>
                                 </content>
                              </Tab>
                              <Tab fx:id="tbTabComicInfo" text="ComicInfo">
                                 <content>
                                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                                       <children>
                                          <fx:include fx:id="comicinfo" source="AbaComicInfo.fxml" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                       </children>
                                    </AnchorPane>
                                 </content>
                              </Tab>
                              <Tab fx:id="tbTabPasta" onSelectionChanged="#onSelectChanged" text="Pastas">
                                 <content>
                                    <AnchorPane prefHeight="200.0" prefWidth="200.0">
                                       <children>
                                          <fx:include fx:id="pastas" source="AbaPastas.fxml" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                       </children>
                                    </AnchorPane>
                                 </content>
                              </Tab>
                              <Tab fx:id="tbTabManga" onSelectionChanged="#onSelectChanged" text="Manga">
                                 <content>
                                    <AnchorPane prefHeight="200.0" prefWidth="200.0">
                                       <children>
                                          <fx:include fx:id="abaManga" source="AbaManga.fxml" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                       </children>
                                    </AnchorPane>
                                 </content>
                              </Tab>
                           </tabs>
                           <VBox.margin>
                              <Insets />
                           </VBox.margin>
                           <padding>
                              <Insets top="15.0" />
                           </padding>
                        </JFXTabPane>
                        <VBox alignment="CENTER_LEFT" styleClass="background-Black1">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <Label fx:id="lblProgresso" maxWidth="1.7976931348623157E308" styleClass="texto-stilo-1" text="Processando" textFill="WHITE" HBox.hgrow="ALWAYS">
                                       <padding>
                                          <Insets left="10.0" right="10.0" />
                                       </padding>
                                       <font>
                                          <Font size="10.0" />
                                       </font>
                                    </Label>
                                 </children>
                                 <VBox.margin>
                                    <Insets left="5.0" right="5.0" top="2.0" />
                                 </VBox.margin>
                              </HBox>
                              <ProgressBar fx:id="pbProgresso" prefHeight="10.0" prefWidth="5000.0" progress="0.49" styleClass="progress-barAzul" VBox.vgrow="ALWAYS">
                                 <VBox.margin>
                                    <Insets bottom="5.0" left="10.0" right="10.0" />
                                 </VBox.margin>
                              </ProgressBar>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  <JFXButton fx:id="btnAtualizar" buttonType="RAISED" minHeight="45.0" minWidth="110.0" onAction="#onBtnAtualizar" text="Atualizar" textFill="WHITE" AnchorPane.rightAnchor="90.0" AnchorPane.topAnchor="0.0">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </JFXButton>
                  <JFXButton fx:id="btnCompartilhamento" alignment="TOP_CENTER" buttonType="RAISED" contentDisplay="GRAPHIC_ONLY" graphicTextGap="0.0" onAction="#onBtnCompartilhamento" prefHeight="45.0" prefWidth="45.0" AnchorPane.rightAnchor="45.0" AnchorPane.topAnchor="0.0">
                     <graphic>
                        <ImageView fx:id="imgCompartilhamento" fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true" translateY="2.0">
                           <image>
                              <Image url="@../images/icoCompartilhamento_48.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </JFXButton>
                  <JFXButton fx:id="btnConfiguracao" alignment="TOP_CENTER" buttonType="RAISED" contentDisplay="GRAPHIC_ONLY" graphicTextGap="0.0" onAction="#onBtnConfiguracao" prefHeight="45.0" prefWidth="45.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <graphic>
                        <ImageView fx:id="imgConfiguracao" fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true" translateY="2.0">
                           <image>
                              <Image url="@../images/icoBtnImportar_48.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </JFXButton>
               </children>
            </AnchorPane>
            <AnchorPane fx:id="apDragOverlay" mouseTransparent="true" style="-fx-background-color: rgba(0,0,0,0.6);" visible="false">
               <children>
                  <VBox alignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <children>
                        <StackPane fx:id="spDragDropZone" maxHeight="200.0" maxWidth="400.0" prefHeight="200.0" prefWidth="400.0">
                           <children>
                              <Label fx:id="lblDragDrop" alignment="CENTER" text="Arraste o arquivo aqui" textFill="WHITE">
                                 <font>
                                    <Font size="20.0" />
                                 </font>
                              </Label>
                           </children>
                        </StackPane>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </children>
      </StackPane>
   </children>
   <stylesheets>
      <URL value="@../css/Paleta_Cores.css" />
      <URL value="@../css/Dark_TelaInicial.css" />
   </stylesheets>
</AnchorPane>
